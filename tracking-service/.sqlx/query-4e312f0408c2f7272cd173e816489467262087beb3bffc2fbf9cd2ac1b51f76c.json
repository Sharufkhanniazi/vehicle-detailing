{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT \n                o.id,\n                o.customer_id,\n                o.detailer_id,\n                o.latitude as customer_lat,\n                o.longitude as customer_lng\n            FROM orders o \n            WHERE o.id = $1\n                AND (o.customer_id = $2 OR o.detailer_id = $2)\n            ",
